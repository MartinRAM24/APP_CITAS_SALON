<%- include('partials/header') %>
<%- include('partials/flash') %>
<h2>Panel de administradora</h2>

<div class="card">
  <h3>🔔 Notificaciones</h3>
  <p>Citas nuevas (últimas 24h): <strong><%= newCount %></strong></p>
  <% if (latestAppointment) { %>
    <p>Última cita agendada: <strong><%= latestAppointment.customer.fullName %></strong> solicitó <strong><%= latestAppointment.service.name %></strong> para el <strong><%= new Date(latestAppointment.startsAt).toLocaleString('es-MX') %></strong>.</p>
  <% } else { %>
    <p>Aún no hay citas registradas.</p>
  <% } %>
</div>

<div class="grid">
  <section class="card">
    <h3>Crear cita manualmente</h3>
    <form action="/admin/citas" method="POST">
      <label>Cliente</label>
      <select name="customerId" required>
        <% clients.forEach(client => { %>
          <option value="<%= client.id %>"><%= client.fullName %> - <%= client.email %></option>
        <% }) %>
      </select>
      <label>Servicio</label>
      <select name="serviceId" required>
        <% services.forEach(service => { %>
          <option value="<%= service.id %>"><%= service.area %> - <%= service.name %></option>
        <% }) %>
      </select>
      <label>Fecha y hora</label>
      <input name="startsAt" type="datetime-local" required />
      <label>Estado</label>
      <select name="status">
        <option>PROGRAMADA</option>
        <option>COMPLETADA</option>
        <option>CANCELADA</option>
      </select>
      <label>Notas</label>
      <textarea name="notes"></textarea>
      <button type="submit">Guardar cita</button>
    </form>
  </section>

  <section class="card">
    <h3>Citas agendadas</h3>
    <table>
      <thead>
        <tr><th>Cliente</th><th>Servicio</th><th>Fecha</th><th>Editar</th></tr>
      </thead>
      <tbody>
        <% appointments.forEach(app => { %>
          <tr>
            <td><%= app.customer.fullName %><br><span class="small"><%= app.customer.email %></span></td>
            <td><%= app.service.name %><br><span class="small"><%= app.status %></span></td>
            <td><%= new Date(app.startsAt).toLocaleString('es-MX') %></td>
            <td>
              <form action="/admin/citas/<%= app.id %>" method="POST">
                <input type="hidden" name="_method" value="POST" />
                <select name="serviceId">
                  <% services.forEach(service => { %>
                    <option value="<%= service.id %>" <%= service.id === app.serviceId ? 'selected' : '' %>><%= service.name %></option>
                  <% }) %>
                </select>
                <input type="datetime-local" name="startsAt" value="<%= new Date(app.startsAt).toISOString().slice(0,16) %>" />
                <select name="status">
                  <option <%= app.status === 'PROGRAMADA' ? 'selected' : '' %>>PROGRAMADA</option>
                  <option <%= app.status === 'COMPLETADA' ? 'selected' : '' %>>COMPLETADA</option>
                  <option <%= app.status === 'CANCELADA' ? 'selected' : '' %>>CANCELADA</option>
                </select>
                <textarea name="notes"><%= app.notes || '' %></textarea>
                <div class="row-actions">
                  <button type="submit">Actualizar</button>
                </div>
              </form>
              <form action="/admin/citas/<%= app.id %>?_method=DELETE" method="POST" class="inline">
                <button type="submit">Eliminar</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </section>
</div>
<%- include('partials/footer') %>
